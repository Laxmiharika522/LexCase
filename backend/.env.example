# Copy this file to .env and fill values

# PostgreSQL (local Docker or AWS RDS)
DATABASE_URL="postgresql+asyncpg://lexcase:lexcase@localhost:5432/lexcase"

# CORS: comma-separated origins (for AWS, use your EC2 public IP)
CORS_ORIGINS="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Auth
JWT_SECRET="replace-with-64-char-random-hex-secret"
ADMIN_EMAIL="admin@lexcase.com"
ADMIN_PASSWORD="Admin@123"
ADMIN_NAME="Firm Administrator"

# Document storage: "local" for dev, "s3" for AWS production
STORAGE_BACKEND="local"
STORAGE_DIR="./storage"

# AWS S3 (only needed when STORAGE_BACKEND=s3)
# On EC2, use an IAM instance role — do NOT hardcode keys in production.
S3_BUCKET_NAME=""
AWS_REGION="us-east-1"

# Emergent Universal LLM Key (optional — for AI document summarization)
EMERGENT_LLM_KEY="sk-emergent-xxxx"

APP_NAME="lexcase"

# development | production
# In production, cookies use secure=True, samesite=none (required for HTTPS cross-site)
# In development, cookies use secure=False, samesite=lax (required for localhost HTTP)
ENVIRONMENT="development"