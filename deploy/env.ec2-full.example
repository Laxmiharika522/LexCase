# Copy to repo root as .env before running docker-compose.ec2-full.yml
#   cp deploy/env.ec2-full.example .env

# Your EC2 instance public IPv4 (Elastic IP recommended)
EC2_PUBLIC_IP=YOUR_EC2_PUBLIC_IP

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=YOUR_64_CHAR_RANDOM_HEX

# PostgreSQL (internal Docker network — not exposed publicly)
POSTGRES_USER=lexcase
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=lexcase

# Admin account created on first seed
ADMIN_EMAIL=admin@lexcase.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Firm Administrator

# Documents: "local" for demo on single EC2, "s3" if IAM role + bucket configured
STORAGE_BACKEND=local
S3_BUCKET_NAME=
AWS_REGION=us-east-1

# Optional — AI document summarization
EMERGENT_LLM_KEY=