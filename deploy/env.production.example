# Production .env for EC2 Docker backend — copy to backend/.env on the instance.
# Fill in values after creating AWS resources in the Console.

# RDS PostgreSQL endpoint (from RDS Console)
DATABASE_URL=postgresql+asyncpg://lexcase:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT:5432/lexcase

# CloudFront distribution URL (frontend) — required for CORS + auth cookies
CORS_ORIGINS=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net
FRONTEND_URL=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=YOUR_64_CHAR_RANDOM_HEX

ADMIN_EMAIL=admin@lexcase.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Firm Administrator

# S3 bucket for case documents (private — EC2 accesses via IAM role)
STORAGE_BACKEND=s3
S3_BUCKET_NAME=lexcase-docs-YOUR-INITIALS
AWS_REGION=us-east-1

# Optional — AI document summarization
EMERGENT_LLM_KEY=

APP_NAME=lexcase
ENVIRONMENT=production