# Production .env for AWS EC2 — copy to /opt/lexcase/backend/.env
# YOU fill in the values after creating AWS resources in the Console.

# RDS PostgreSQL endpoint (from RDS Console)
DATABASE_URL=postgresql+asyncpg://lexcase:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT:5432/lexcase

# Your EC2 public IP or domain
CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=YOUR_64_CHAR_RANDOM_HEX

ADMIN_EMAIL=admin@lexcase.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Firm Administrator

# AWS S3 document storage
STORAGE_BACKEND=s3
S3_BUCKET_NAME=lexcase-docs-YOUR-INITIALS
AWS_REGION=us-east-1

# Optional — AI summarization
EMERGENT_LLM_KEY=

APP_NAME=lexcase
ENVIRONMENT=production